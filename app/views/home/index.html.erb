<div class="bg-white">
  <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6 sm:py-8 lg:max-w-7xl lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Customers also purchased</h2>
      <div class="mt-6 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
        <% @properties.each do |property| %>
          <div class="group relative">
            <div class="aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-md bg-gray-200 group-hover:opacity-75">
              <img src="https://images.ctfassets.net/n2ifzifcqscw/1ACJoYTLdkE08Z48FgMxDQ/af86727bfe7db83381b56e098fa2f425/Airbnb-alternatives-Hero-image.jpeg" alt="Front of men&#039;s Basic Tee in black." class="h-full w-full object-cover object-center lg:h-full lg:w-full">
            </div>
            <div class="mt-2">
              <div class="flex justify-between">
                <h3 class="text-base font-medium text-gray-700">
                  <a href="#">
                    <span aria-hidden="true" class="absolute inset-0"></span>
                    <%= property.city %> <%= property.country %>
                  </a>
                </h3>
                <p class="flex text-sm items-center font-light">
                  <svg 
                    class="mr-1 block w-3 h-3 fill-current"
                    xmlns="http://www.w3.org/2000/svg" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke-width="1.5" 
                    stroke="currentColor" 
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                  </svg>
                  4.95
                </p>
              </div>
              <p class="mt-0.5 text-sm text-gray-500">Hosted by Daniel</p>
              <p class="mt-0.5 text-sm text-gray-500">20-25 July</p>
              <p class="mt-0.5 text-sm font-light text-black">
                <span class="font-medium"><%= humanized_money_with_symbol(property.price) %></span> night
              </p>
            </div>
          </div>
        <% end %>
      </div>
  </div>
</div>