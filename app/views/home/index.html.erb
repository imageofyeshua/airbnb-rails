<div class="bg-white">
  <div class="mx-auto max-w-2xl px-4 py-4 sm:px-6 sm:py-8 lg:max-w-7xl lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Customers also purchased</h2>
      <div class="mt-6 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
        <% @properties.each do |property| %>
          <div class="group relative">
            <div class="relative overflow-hidden rounded-md bg-gray-200">
              <!-- Slider main container -->
              <div class="swiper aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-md bg-gray-200">
                <!-- Additional required wrapper -->
                <div class="swiper-wrapper">
                  <!-- Slides -->
                  <% property.images.each do |image| %>
                    <%= image_tag image, class: "swiper-slide h-full w-full object-cover object-center lg:h-full lg:w-full" %>
                  <% end %>
                </div>

                <!-- If we need navigation buttons -->
                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
              </div>
              <div class="absolute z-10 right-0 top-0 m-4">
                <svg xmlns="http://www.w3.org/2000/svg" 
                  viewBox="0 0 32 32" 
                  aria-hidden="true" 
                  role="presentation" 
                  focusable="false"
                  class="block h-6 w-6 stroke-white stroke-2 fill-none"
                  style="overflow: visible;"
                  data-controller="wishlist"
                  data-user-logged-in="<%= user_signed_in? %>"
                  data-action="click->wishlist#updateWishlistStatus"
                  data-status="false"
                >
                  <path d="M16 28c7-4.73 14-10 14-17a6.98 6.98 0 0 0-7-7c-1.8 0-3.58.68-4.95 2.05L16 8.1l-2.05-2.05a6.98 6.98 0 0 0-9.9 0A6.98 6.98 0 0 0 2 11c0 7 7 12.27 14 17z"></path>
              </svg>
              </div>
            </div>

            <div class="mt-2">
              <div class="flex justify-between">
                <h3 class="text-base font-medium text-gray-700">
                  <a href="#">
                    <span aria-hidden="true" class="absolute inset-0"></span>
                    <%= property.city %> <%= property.country %>
                  </a>
                </h3>
                <p class="flex text-sm items-center font-light">
                  <svg 
                    class="mr-1 block w-3 h-3 fill-current"
                    xmlns="http://www.w3.org/2000/svg" 
                    fill="none" 
                    viewBox="0 0 24 24" 
                    stroke-width="1.5" 
                    stroke="currentColor" 
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                  </svg>
                  <%= property.average_final_rating.round(2) %>
                </p>
              </div>
              <p class="mt-0.5 text-sm text-gray-500">Hosted by Daniel</p>
              <p class="mt-0.5 text-sm text-gray-500">20-25 July</p>
              <p class="mt-0.5 text-sm font-light text-black">
                <span class="font-medium"><%= humanized_money_with_symbol(property.price) %></span> night
              </p>
            </div>
          </div>
        <% end %>
      </div>
  </div>
</div>